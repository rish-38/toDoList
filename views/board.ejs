<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <title>todolist</title>
</head>

<body class="dark-theme">

    <div class="btn">
        <button class="add"> Add <i class="fa-solid fa-plus"></i></button>
    </div>

    <div class="canvas">
        <% if(allNotes && allNotes.length > 0) { %>

                <% allNotes.forEach((note, index)=> { %>
                        <form action="/" method="post" class="note" id=`note-<%=index %>`>
                            <input type='text' class="title" name="title" placeholder="Untitled" value="<%= note.title %>" >
                        <a name="action" value="delete" class="icon delete"><i class="fa-solid fa-trash"></i></a>
                            <textarea name="task" class="tasks" placeholder="What you wish to do :>" ><%= note.tasks %></textarea>
                        </form>
                    <% }) %>
            </ul>
            <% } else { %>
                <p>No notes available. Add one above!</p>
                <% } %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.15/dist/Draggable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.15"></script>
    <script type="module" src="/deploy.js"></script>
</body>

</html>